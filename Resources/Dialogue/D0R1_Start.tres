[sub_resource type="Resource" id="e1"]
script = ExtResource("2")
text = "Oh! You're awake! I thought I was alone forever."

[sub_resource type="Resource" id="e2"]
script = ExtResource("2")
text = "I'm D-0R1. I think I'm a door. I'm very good at being closed."

[sub_resource type="Resource" id="e3"]
